 def ler_e_limpar(caminho_pasta: str, nome_arquivo: str, label: str) -> pd.DataFrame:
    print(f"\n{'═'*55}")
    print(f"  LENDO E LIMPANDO: {label}")
    print(f"{'═'*55}")
    caminho = os.path.join(caminho_pasta, nome_arquivo)
    df = pd.read_csv(caminho, sep='\t', skiprows=8, encoding='latin1', engine='python')
    print(f"[{label}] Leitura:        {len(df):>10,} linhas brutas")

    df.columns = df.columns.str.strip()
    df = df.rename(columns=NORMALIZAR_COLUNAS)
    df = df[COLUNAS_SAP].copy()
    df = df[df['Empr'].notna()]
    df = df[df['Empr'] != 'Empr']
    df['Marca'] = pd.NA
    df['Tipo de Faturamento'] = pd.NA

    df['Empr'] = (
        df['Empr'].astype(str).str.strip()
        .str.replace('.0', '', regex=False).astype(int)
    )
    #Exclusão da conta 1103100020 — PRÉVIA APENAS, NÃO EXECUTAR NO FECHAMENTO
    df = df[df['Empr'] != 1103100020]

    for col in ['Data doc.', 'Data base']:
        df[col] = pd.to_datetime(
            df[col].astype(str).str.replace('.', '/', regex=False),
            dayfirst=True, errors='coerce'
        )

    cliente_num = pd.to_numeric(df['Cliente'], errors='coerce')
    num_doc = df['Nº Doc'].astype(str).str.strip().str.upper()
    cond = (cliente_num > 4_000_000_000) | (cliente_num == 500) | (num_doc == 'DV')
    df['Tipo de Faturamento'] = np.where(cond, 'Particular', 'Fatura')

    print(f"[{label}] Após limpeza:   {len(df):>10,} linhas")
    return df


def agregar_08(df: pd.DataFrame, label: str) -> pd.DataFrame:
    """Agrega Base 08 pelas 8 colunas chave, somando Mont. em MI."""
    df_agr = (
        df[COLUNAS_BASE_08 + ['Mont. em MI']]
        .groupby(COLUNAS_BASE_08, dropna=False)
        .agg(Valor=('Mont. em MI', 'sum'))
        .reset_index()
        .rename(columns={'Valor': 'Mont. em MI'})
    )
    print(f"[{label}] Agregação:      {len(df):>10,} → {len(df_agr):,} linhas "
          f"({len(df) - len(df_agr):,} comprimidas)")
    print(f"[{label}] Mont. em MI:    {df_agr['Mont. em MI'].sum():>15,.2f}")
    return df_agr

