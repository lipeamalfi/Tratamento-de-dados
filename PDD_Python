# UTILITÁRIO DE NORMALIZAÇÃO

def norm(series: pd.Series) -> pd.Series:
    """Minúsculo + sem acento + strip. Preserva NaN."""
    return (
        series.astype(str)
        .str.strip()
        .apply(lambda x: unidecode(x).lower() if x not in ('nan', 'None', '') else pd.NA)
    )


